---
import { getCollection } from "astro:content";
import Section from "~/components/Section.astro";
import ExampleFactorySection from "~/components/user-components/ExampleFactorySection.astro";

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

const rawPromptFiles = import.meta.glob<string>(
  "/src/content/example-factories/**/*.md",
  { query: "?raw", import: "default", eager: true }
);

const factoryEntries = await getCollection("exampleFactories");
const promptEntries = await getCollection("exampleFactoryPrompts");

function getRawContent(entryId: string): string | undefined {
  const pathVariants = [
    `/src/content/example-factories/${entryId}.md`,
    `src/content/example-factories/${entryId}.md`,
  ];
  for (const pathKey of pathVariants) {
    const value = rawPromptFiles[pathKey];
    if (typeof value === "string") return value;
    if (value && typeof (value as { default?: string }).default === "string") {
      return (value as { default: string }).default;
    }
  }
  return undefined;
}

const promptHtmlByKey = new Map<string, string>();
for (const entry of promptEntries) {
  const raw = getRawContent(entry.id);
  if (raw !== undefined) {
    const safe = escapeHtml(raw);
    promptHtmlByKey.set(entry.id, `<pre class="raw-prompt">${safe}</pre>`);
  }
}

function augmentItems<T extends { name: string }>(factoryId: string, items: T[]) {
  return items.map((item) => ({
    ...item,
    promptHtml: promptHtmlByKey.get(`${factoryId}/${item.name}`),
  }));
}

const sorted = factoryEntries.sort((a, b) => a.id.localeCompare(b.id));
const augmented = sorted.map((entry) => {
  const data = entry.data;
  return {
    ...data,
    skills: augmentItems(entry.id, data.skills),
    commands: augmentItems(entry.id, data.commands),
    agents: augmentItems(entry.id, data.agents),
    workflows: augmentItems(entry.id, data.workflows),
  };
});
---

<Section
  title="Example <span class='light-text'>factories</span>"
  description="See how skills, commands, agents, and workflows compose for different application styles."
>
  {augmented.map((factory) => (
    <ExampleFactorySection factory={factory} />
  ))}
</Section>
