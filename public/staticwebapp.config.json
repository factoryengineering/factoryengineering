{
  "mimeTypes": {
    ".md": "text/markdown; charset=utf-8",
    ".mdx": "text/markdown; charset=utf-8"
  },
  "routes": [
    {
      "route": "/markdown/*",
      "headers": {
        "Cache-Control": "public, max-age=300, s-maxage=300",
        "X-Content-Type-Options": "nosniff"
      }
    }
  ]
}
